# Variabili lette via getenv() da Config/config.php (e quindi da Config/configFramework.php
# generato in installazione). Non vengono caricate automaticamente da questo file: vanno rese
# disponibili come variabili d'ambiente del processo PHP (Docker env_file, SetEnv del web
# server, systemd EnvironmentFile, export manuale, ecc.).
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USERNAME=
DATABASE_PASSWORD=
ENCRYPTION_PASSPHRASE=
